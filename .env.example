# 環境変数設定ファイル（ローカル開発用）
# このファイルは .gitignore に追加してコミットしないでください

# Supabase接続情報
# あなたのSupabaseプロジェクトの実際の値に置き換えてください
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# 設定方法:
# 1. https://app.supabase.com でプロジェクトを開く
# 2. Settings > API から URL と anon/public key をコピー
# 3. 上記のプレースホルダーを実際の値に置き換える
#
# 例:
# SUPABASE_URL=https://abcdefghijklmnopqrstuv.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJ...

# その他の環境変数（必要に応じて追加）
# DEBUG=true
# LOG_LEVEL=info
